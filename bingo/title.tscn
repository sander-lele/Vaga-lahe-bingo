[node name="Label2" type="Label" parent="GuidePanel/VBoxContainer" unique_id=1344927115]
custom_minimum_size = Vector2(700, 0)
layout_mode = 2
size_flags_horizontal = 4
size_flags_vertical = 6
text = "A total of 48 balls are drawn. Each ball is labeled with a letter and a number.
If one of the drawn balls match one of the numbers on your board, then you can mark it by clicking it.
You earn points by completing specific patterns.
The following games are:
Center Square Game: Win if the first ball drawn matches your center square.
Corner Game: Win if all four corner squares are marked within the first 33 balls.
Diagonal Game: Win if you complete two diagonals (9 squares total) within the first 38 balls.
Full Game: Win if all squares on the board are marked."
label_settings = SubResource("LabelSettings_kpexm")
vertical_alignment = 1
autowrap_mode = 3

